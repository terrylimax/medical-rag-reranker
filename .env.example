POSTGRES_DB=medical_rag
POSTGRES_USER=medical_rag
POSTGRES_PASSWORD=medical_rag
POSTGRES_PORT=5432
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
JOBS_API_WORKERS=2
NGINX_PORT=8080

# Remote vector backend. Keep RETRIEVAL_VECTOR_BACKEND=local for local dense
# indices; set it to qdrant when QDRANT_URL points to Qdrant Cloud or a remote
# Qdrant service.
RETRIEVAL_VECTOR_BACKEND=local
RETRIEVAL_DENSE_BACKEND=dense
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=medical_rag_docs
QDRANT_TIMEOUT_SECONDS=60

# For Qdrant-backed generation, set GENERATION_CORPUS_PATH=null and point
# GENERATION_INDEX_PATH to the lightweight Qdrant manifest in /app/artifacts.
GENERATION_CORPUS_PATH=/app/data/processed/corpus.jsonl
GENERATION_INDEX_PATH=/app/artifacts/bm25_index.json.gz

# Remote OpenAI-compatible generation backend, including vLLM and RunPod vLLM.
GENERATION_BACKEND=local
GENERATION_LLM_MODEL_NAME=google/flan-t5-small
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_API_TYPE=chat
VLLM_TIMEOUT_SECONDS=120

# Optional OpenAI-compatible LLM-as-a-Judge endpoint. Use a separate endpoint
# from the generator when comparing RAG methods.
LLM_JUDGE_BASE_URL=
LLM_JUDGE_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506
LLM_JUDGE_API_KEY=
LLM_JUDGE_TIMEOUT_SECONDS=300
